{
  "name": "@guataiba/isac-core",
  "version": "2.2.0",
  "description": "Framework-agnostic pipeline engine for ISAC — Intelligent Site Analysis & Cloning",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "design-system",
    "screenshot",
    "ai",
    "claude",
    "site-analysis",
    "web-cloning"
  ],
  "author": "Lucian Fialho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guataiba/isac-cli.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/guataiba/isac-cli#readme",
  "bugs": {
    "url": "https://github.com/guataiba/isac-cli/issues"
  },
  "dependencies": {
    "agent-browser": "^0.16.1",
    "chalk": "^5.4.1",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/pngjs": "^6.0.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
