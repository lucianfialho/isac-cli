{
  "name": "@guataiba/isac-cli",
  "version": "2.0.0",
  "description": "ISAC CLI — Intelligent Site Analysis & Cloning. Captures screenshots, extracts design systems, and generates pixel-perfect Next.js replicas powered by Claude Code.",
  "type": "module",
  "bin": {
    "isac": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "design-system",
    "screenshot",
    "nextjs",
    "claude",
    "ai",
    "web-cloning",
    "site-analysis"
  ],
  "author": "Lucian Fialho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guataiba/isac-cli.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/guataiba/isac-cli#readme",
  "bugs": {
    "url": "https://github.com/guataiba/isac-cli/issues"
  },
  "dependencies": {
    "@guataiba/isac-core": "workspace:*",
    "@guataiba/isac-nextjs": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
